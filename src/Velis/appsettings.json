{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ariston": {
    "BaseUrl": "https://api.ariston.net/v1",
    "Username": "your_username",
    "Password": "your_password",
    "GatewayId": "your_gateway_id",
    "DeviceType": "'lydos_hybrid' ? 'se' : 'med'"
  },
  "Calendar": {
    "Aliases": "your_calendar_aliases",
    "TemperatureAliases": "your_calendar_temperature_alias",
    "Url": "your_calendar_url"
  },
  "IdleTemperature": 50
}
